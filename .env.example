# =============================================================================
# Weekly Task Manager — template .env (committabil, FĂRĂ secrete reale)
# Copiază în `.env` și completează valorile marcate OBLIGATORIU / MUST FILL.
# Toate variabilele de mai jos sunt citite efectiv de cod (Settings în
# backend/app/core/config.py). Nu adăuga variabile pe care aplicația nu le citește.
# =============================================================================

# -----------------------------------------------------------------------------
# Bază de date (OBLIGATORIU)
# -----------------------------------------------------------------------------
# DATABASE_URL este citit de backend (config.py), de Alembic (alembic/env.py)
# și de start.sh. HOST-ul TREBUIE să fie numele serviciului din docker-compose
# (`postgres`), iar user/parola/db TREBUIE să coincidă cu POSTGRES_* de mai jos.
DATABASE_URL=postgresql://taskuser:CHANGE_ME_strong_db_password@postgres:5432/taskmanager

# Credențialele containerului Postgres. Trebuie să fie IDENTICE cu cele din
# DATABASE_URL. ATENȚIE: docker-compose.yml are momentan aceste valori hardcodate
# — vezi nota din raport (trebuie făcute să citească din .env, sau editate manual
# în compose ca să coincidă).
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=taskmanager

# -----------------------------------------------------------------------------
# Telegram — bot principal (OBLIGATORIU pentru login 2FA + notificări)
# -----------------------------------------------------------------------------
# Token de la @BotFather. Fără el, codurile 2FA și notificările nu se trimit.
TELEGRAM_BOT_TOKEN=
# Chat ID-ul tău Telegram — folosit la seed-ul admin-ului inițial.
TELEGRAM_CHAT_ID=
# Username public al botului (FĂRĂ @) — construiește deep-link t.me/<user>?start=...
# Opțional; dacă e gol, butonul de deep-link e ascuns.
TELEGRAM_BOT_USERNAME=

# -----------------------------------------------------------------------------
# Telegram — bot admin separat (opțional)
# -----------------------------------------------------------------------------
# Dacă e setat, adminii primesc coduri 2FA + remindere prin acest bot.
# Dacă e gol, se folosește botul principal.
ADMIN_TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Aplicație (OBLIGATORIU)
# -----------------------------------------------------------------------------
PORT=3001
# URL-ul public al frontend-ului (folosit în linkuri/CORS). În producție = domeniul HTTPS.
FRONTEND_URL=https://taskmanager.sma1lsoft.eu
NODE_ENV=production

# -----------------------------------------------------------------------------
# Auth / Securitate (OBLIGATORIU)
# -----------------------------------------------------------------------------
# PIN-ul inițial al adminului (fallback la refresh după expirarea tokenului). SCHIMBĂ-L.
APP_PIN=
# Secret JWT — generează cu:  openssl rand -hex 32
JWT_SECRET=
# Durata sesiunii (ore) înainte de re-login.
JWT_EXPIRE_HOURS=12
# TTL cod 2FA (minute) și nr. max de încercări.
LOGIN_CODE_TTL_MINUTES=5
LOGIN_CODE_MAX_ATTEMPTS=5

# -----------------------------------------------------------------------------
# Admin inițial (seed la primul start; ignorat după ce există deja un admin)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_EMAIL=
ADMIN_FULL_NAME=Administrator
# Parola inițială a adminului — SCHIMB-O din profil după primul login.
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# AI — OpenRouter (opțional; fără cheie, AI-ul cade pe euristici locale)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# -----------------------------------------------------------------------------
# AI — Anthropic / Claude (opțional, legacy; păstrat pentru compatibilitate)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
