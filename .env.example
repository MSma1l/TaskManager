# Database
DATABASE_URL=postgresql://taskuser:taskpass@postgres:5432/taskmanager

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here   # used to seed the initial admin's chat

# App
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Auth
APP_PIN=1234                          # initial admin PIN (used for refresh after token expiry)
JWT_SECRET=change_this_to_a_random_secret_string
JWT_EXPIRE_HOURS=12                   # session length before re-login is required
LOGIN_CODE_TTL_MINUTES=5              # 2FA code lifetime
LOGIN_CODE_MAX_ATTEMPTS=5

# Initial admin (seeded on first run; ignored after the first admin exists)
ADMIN_USERNAME=admin
ADMIN_EMAIL=
ADMIN_FULL_NAME=Administrator
